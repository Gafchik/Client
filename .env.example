# === БД (поднимается в Docker: docker compose up -d db) ===
POSTGRES_DB=ai_agent_team
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# Порт Postgres на хосте (контейнер пробрасывает сюда внутренний 5432)
POSTGRES_PORT=35433

# === Локальный запуск API (npm run start) ===
# API ходит в БД докера на localhost:POSTGRES_PORT
DATABASE_HOST=localhost
DATABASE_PORT=35433
DATABASE_NAME=ai_agent_team
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
# Порт API. 3000 часто занят локальным Next-приложением, поэтому
# дефолт — 3010. Vite-прокси (apps/web/vite.config.ts) ходит сюда же.
PORT=3010

# === Пути к проектам для агентов ===
# При локальном запуске CONTAINER_PROJECTS_ROOT ДОЛЖЕН быть равен
# LOCAL_PROJECTS_ROOT — тогда маппинг путей становится no-op и API
# работает с локальным диском напрямую (без тома Docker).
LOCAL_PROJECTS_ROOT=/Users/evgenii
CONTAINER_PROJECTS_ROOT=/Users/evgenii

TZ=Europe/Kiev

# === Отладка ранов ===
# SAVE_AGENT_ARTIFACTS=1 — сохранять дампы ответов каждого агента в
#   apps/api/runs/<runId>/artifacts/<role>.json (промпт, rawResponse,
#   parsed, usage). Чисто отладочный формат: рантайм и контроллер читают
#   только runs/<id>/final-report.json, эти дампы никто не парсит.
#   По умолчанию выкл — не плодит мусор и не коммитит его в репо.
# SAVE_AGENT_ARTIFACTS=1

