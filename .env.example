# Neo4j (persistent knowledge graph storage) — поднимается в Docker (см. docker-compose.yml).
NEO4J_USER=neo4j
NEO4J_PASSWORD=clientgraph
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
TZ=Europe/Kiev

# Bolt-адрес, который использует apps/api (backend запускается локально, без Docker).
NEO4J_URI=bolt://127.0.0.1:7687

# Bootstrap-значения для первого провайдера, создаваемого автоматически при пустом Neo4j.
# Источник истины после первого старта — Neo4j CRUD (apps/api/src/provider-store.ts),
# управляется через UI (страница "Провайдеры"), а не через .env.
CLIENT_PROVIDER_BASE_URL=
CLIENT_PROVIDER_MODEL=
CLIENT_PROVIDER_API_KEY=

# Redis (ephemeral pipeline-status кеш, TTL, см. docker-compose.yml) — порт
# 6380, не 6379: на хосте уже может быть занят чужим redis (например,
# соседнего проекта). Если не заданы, apps/api/src/redis-client.ts падает
# на 127.0.0.1:6380 по умолчанию.
REDIS_HOST=127.0.0.1
REDIS_PORT=6380
